# ──────────────────────────────────────────────
# CleverBooks — Root Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cleverbooks?retryWrites=true&w=majority

# Webhook/Notification endpoint (e.g. Pipedream, webhook.site)
WEBHOOK_URL=https://your-endpoint.m.pipedream.net
